	(text "Unused Gates. Given the redundant\ngates elsewhere, it seems possible\nto reduce the chip count of this device.\nThe goal is to get something that works,\nthough, and this configuration is \ncurrently working on a breadboard."
		(exclude_from_sim no)
		(at 15.24 127 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "6623b8e9-2a6a-47dd-a6d4-b60d1c311cbf")
	)
	(text "Machine State"
		(exclude_from_sim no)
		(at 102.87 99.822 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "71608165-e1f7-44a6-8fa9-c17897538066")
	)
	(text "The device cycles through four states, stored in Machine State.\n0-2: The device is reciving or waiting for a byte a byte for each state.\n3: Once the device recives 3 bytes, it then sends a byte.\nThe behavior is the same for both reads and writes to the eeprom,\nresulting in a garbage byte being sent for either operation."
		(exclude_from_sim no)
		(at 179.324 38.862 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "889fc261-d0cc-4b42-a9d8-6dc6f2c7bec4")
	)
	(text "Clock Divider"
		(exclude_from_sim no)
		(at 25.908 187.96 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "8d48845a-1fed-457b-8208-f88e19312aec")
	)
	(text "Also redundant, should be \nable to use UART Data \nbit-time instead."
		(exclude_from_sim no)
		(at 217.678 151.13 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "b3698845-7fe9-4268-b139-3c20ed3e9607")
	)
	(text "UART Activity Latch\n"
		(exclude_from_sim no)
		(at 101.346 185.928 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "cf262f34-e709-4464-8d89-5d1671e60847")
	)
	(text "Gate is redundant. \nCould use Primary\nClock instead.\n"
		(exclude_from_sim no)
		(at 71.882 74.168 0)
		(effects
			(font
				(size 1.2192 1.2192)
			)
			(justify left)
		)
		(uuid "d797ace9-1061-4aa3-9ef0-9149fe8a9ff5")
	)
	(text "UART Clock Divider"
		(exclude_from_sim no)
		(at 102.108 113.03 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "f3d0507f-4f40-4881-8d81-466ed9aed993")
